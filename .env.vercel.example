# Copy to .env.vercel, fill real values, then push with:
# bash scripts/vercel-env-push.sh .env.vercel production
# If Vercel Git is connected, also push preview branch vars:
# bash scripts/vercel-env-push.sh .env.vercel preview main

# Supabase/Postgres pooled connection string.
# Supabase dashboard: Project Settings -> Database -> Connection string -> Transaction pooler.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
JWT_SECRET=CHANGE_ME_RANDOM_32_BYTES_OR_LONGER
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

VITE_APP_ID=CHANGE_ME
VITE_OAUTH_PORTAL_URL=https://CHANGE_ME
VITE_API_BASE_URL=https://CHANGE_ME_API_DOMAIN
ALLOWED_WEB_ORIGINS=https://CHANGE_ME_STATIC_FRONTEND_DOMAIN
PUBLIC_WEB_ORIGIN=https://CHANGE_ME_STATIC_FRONTEND_DOMAIN
OAUTH_SERVER_URL=https://CHANGE_ME
OWNER_OPEN_ID=CHANGE_ME_OWNER_OPEN_ID

# Optional for now. Fill later when enabling AI generation/transcription.
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=CHANGE_ME
