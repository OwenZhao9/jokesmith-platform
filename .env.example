# AI API Configuration (server-side only)
# DeepSeek is OpenAI-compatible.
# BUILT_IN_FORGE_API_URL=https://api.deepseek.com
# BUILT_IN_FORGE_API_KEY=your_deepseek_api_key_here

# Database Configuration
# Production setup: Supabase/Postgres transaction pooler.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# OAuth Configuration (Optional - only needed for login features)
# VITE_APP_ID=your_app_id
# VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com
# VITE_API_BASE_URL=https://your-api-domain.com
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# VITE_SUPABASE_ADMIN_FUNCTION=jokesmith-admin
# ALLOWED_WEB_ORIGINS=https://your-static-frontend.com
# PUBLIC_WEB_ORIGIN=https://your-static-frontend.com
# OAUTH_SERVER_URL=https://your-oauth-server.com
# JWT_SECRET=your_jwt_secret
# OWNER_OPEN_ID=your_owner_open_id
# ADMIN_PASSWORD=your_admin_password
# PUBLIC_ACCESS_PASSWORD=your_public_site_access_password
# PUBLIC_AI_RATE_LIMIT_PER_HOUR=20

# Vercel runtime notes:
# Set these variables in Vercel Project Settings for both Preview and Production.
# Run `pnpm db:migrate` against the production DATABASE_URL before using admin stats.

# Port Configuration (Optional)
# PORT=3000
