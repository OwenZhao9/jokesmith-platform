# Forge API Configuration (Required for AI features)
# Get your API key from https://forge.manus.im or your Forge API provider
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your_api_key_here

# Database Configuration (Optional - only needed if using database features)
# DATABASE_URL=mysql://user:password@localhost:3306/jokesmith

# OAuth Configuration (Optional - only needed for login features)
# VITE_APP_ID=your_app_id
# OAUTH_SERVER_URL=https://your-oauth-server.com
# JWT_SECRET=your_jwt_secret
# OWNER_OPEN_ID=your_owner_open_id

# Port Configuration (Optional)
# PORT=3000
